# STAGE 1: Cache Dependencies
FROM eclipse-temurin:17-jdk AS deps
WORKDIR /app
COPY gradlew .
COPY gradle gradle
COPY build.gradle settings.gradle ./
# Pre-download dependencies
RUN ./gradlew build -x test --no-daemon > /dev/null 2>&1 || true

# STAGE 2: Development Environment
FROM eclipse-temurin:17-jdk AS dev
WORKDIR /app

# Install inotify-tools using apt (Debian/Ubuntu version)
RUN apt-get update && apt-get install -y inotify-tools && rm -rf /var/lib/apt/lists/*

# Copy cached gradle from stage 1
COPY --from=deps /root/.gradle /root/.gradle
COPY --from=deps /app /app

# Copy source and script
COPY . .
RUN chmod +x gradlew docker-entrypoint.sh

EXPOSE 8080
ENTRYPOINT ["./docker-entrypoint.sh"]